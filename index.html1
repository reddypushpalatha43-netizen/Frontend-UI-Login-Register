<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Advanced Auth UI</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<div class="container">

  <!-- Login -->
  <div class="form-box" id="loginBox">
    <h2>Login</h2>
    <form id="loginForm">
      <input type="email" id="loginEmail" placeholder="Email" required>

      <div class="password-box">
        <input type="password" id="loginPass" placeholder="Password" required>
        <span onclick="togglePassword('loginPass')">👁</span>
      </div>

      <button type="submit">Login</button>
      <p>New here? <span onclick="showRegister()">Create Account</span></p>
    </form>
  </div>

  <!-- Register -->
  <div class="form-box hidden" id="registerBox">
    <h2>Register</h2>
    <form id="registerForm">
      <input type="text" id="name" placeholder="Full Name" required>

      <input type="email" id="email" placeholder="Email" required>

      <!-- AJAX username check -->
      <input type="text" id="username" placeholder="Username" required onkeyup="checkUsername()">
      <small id="userMsg"></small>

      <div class="password-box">
        <input type="password" id="pass" placeholder="Password" required onkeyup="checkStrength()">
        <span onclick="togglePassword('pass')">👁</span>
      </div>

      <div id="strength"></div>

      <div class="password-box">
        <input type="password" id="confirmPass" placeholder="Confirm Password" required>
        <span onclick="togglePassword('confirmPass')">👁</span>
      </div>

      <button type="submit">Register</button>
      <p>Already have account? <span onclick="showLogin()">Login</span></p>
    </form>
  </div>

</div>

<script src="script.js"></script>
</body>
</html>